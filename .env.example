# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (for Whisper video transcription)
OPENAI_API_KEY=your_openai_api_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./recipes.db

# Optional: Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Instagram credentials (for fetching posts)
# Run: python scripts/instagram_login.py to create session
INSTAGRAM_USERNAME=

# Optional: Notion integration
NOTION_TOKEN=
NOTION_COOKING_PAGE_ID=
NOTION_AUTO_SYNC=false
